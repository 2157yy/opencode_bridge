{
  "name": "opencode_bridge",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs src test tests",
    "test": "npm run build && node --test dist/test/*.js tests/*.cjs",
    "verify": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.4.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
